# Azure OpenAI
AZURE_API_BASE=https://your-resource.services.ai.azure.com/openai/v1
AZURE_API_KEY=your-azure-api-key

# LiteLLM proxy master key (used for auth against the proxy)
LITELLM_MASTER_KEY=sk-local-change-this

# CLIProxyAPI (preferred)
# Generate with: openssl rand -hex 32
CLIPROXY_LOCAL_TOKEN=replace-with-a-random-local-token
CLIPROXY_PORT=8317
AZURE_DEFAULT_DEPLOYMENT=gpt-5.6-sol
# Optional tier-specific Azure deployment names:
# AZURE_OPUS_DEPLOYMENT=gpt-5.6-sol
# AZURE_SONNET_DEPLOYMENT=gpt-5.6-terra
# AZURE_HAIKU_DEPLOYMENT=gpt-5.6-luna

# Claude Code env vars (set these before running `claude`)
# ANTHROPIC_BASE_URL=http://127.0.0.1:4000
# ANTHROPIC_AUTH_TOKEN=sk-local-change-this
# CLAUDE_CODE_ENABLE_GATEWAY_MODEL_DISCOVERY=1
# ANTHROPIC_DEFAULT_OPUS_MODEL=gpt-5.6-sol
# ANTHROPIC_DEFAULT_SONNET_MODEL=gpt-5.6-terra
# ANTHROPIC_DEFAULT_HAIKU_MODEL=gpt-5.6-luna
# CLAUDE_CODE_SUBAGENT_MODEL=gpt-5.6-terra
